# Ventra Insurance Group — environment variables
# Copy to .env.local and fill in. All values are [CONFIRM] pending manager input.

# --- Contact details (shown in footer / contact page) ---
# [CONFIRM] CallRail tracking number, e.g. (305) 555-0100
NEXT_PUBLIC_CONTACT_PHONE=
# [CONFIRM] routing / inbox email
NEXT_PUBLIC_CONTACT_EMAIL=
# [CONFIRM] business mailing address
NEXT_PUBLIC_CONTACT_ADDRESS=

# --- Contact form submission (phase 7) ---
# [CONFIRM] GoHighLevel / CRM webhook URL or email endpoint
CONTACT_FORM_ENDPOINT=

# --- Analytics / tracking (phase 8) — do NOT hardcode IDs in code ---
# [CONFIRM] which CallRail script / Google Ads / Meta pixel are in use
NEXT_PUBLIC_GOOGLE_ADS_ID=
NEXT_PUBLIC_META_PIXEL_ID=
NEXT_PUBLIC_CALLRAIL_ID=
